# Copy to .env and fill in. Never commit .env.
# Credentials come from https://developer.safaricom.co.ke -> My Apps

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey

# Public HTTPS base URL Safaricom posts results to.
# Run `ngrok http 3000` and paste the https URL here (no trailing slash).
PUBLIC_BASE_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

PORT=3000
