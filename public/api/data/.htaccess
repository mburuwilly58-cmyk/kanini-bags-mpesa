# This folder holds payment records and the cached access token.
# It sits inside the web root, so without this it would be downloadable
# by anyone who guesses the URL. Deny all direct web access.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
